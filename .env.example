# CRITICAL: change these before any non-development deployment
PUBLIC_BASE_URL=http://localhost:3000   # embedded in every marketplace URL — must be reachable by clients
SKILLSHELF_SESSION_SECRET=dev-session-secret-change-me  # generate with: python -c "import secrets; print(secrets.token_hex(32))"

PORT=3000
SKILLSHELF_DATA_DIR=./.skillshelf-data
NODE_ENV=development

# Optional: path to an encryption key file for auth provider client secrets (default: <data_dir>/keys/secret_box.key)
# SKILLSHELF_ENCRYPTION_KEY_PATH=/path/to/secret_box.key

# Optional: log level (DEBUG, INFO, WARNING, ERROR) — default: INFO
# SKILLSHELF_LOG_LEVEL=INFO
